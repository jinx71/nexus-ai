# ── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# Where the React client is served from (for CORS).
CLIENT_URL=http://localhost:3000

# ── Database ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/nexus-ai

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ── AI provider (OpenAI-compatible) ──────────────────────────────────────────
# Leave AI_API_KEY blank to run in DEMO MODE: the app streams a canned response
# token-by-token so the full UX works with zero signup.
#
# To stream REAL completions, drop in a key. Defaults target Groq (free tier),
# but any OpenAI-compatible endpoint works — just change AI_BASE_URL + AI_MODEL.
#   Groq:      AI_BASE_URL=https://api.groq.com/openai/v1
#   OpenAI:    AI_BASE_URL=https://api.openai.com/v1
#   Together:  AI_BASE_URL=https://api.together.xyz/v1
#
# Model names change over time — check your provider's current model list and
# set AI_MODEL accordingly (the value below is a sensible Groq default).
AI_API_KEY=
AI_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.1-8b-instant
